# Copy to .env and fill in your API key.
GROQ_API_KEY=
# Optional fallback if you want to use OpenAI instead of Groq.
OPENAI_API_KEY=
# Optional: override model name (default: llama-3.3-70b-versatile)
OPENAI_MODEL=llama-3.3-70b-versatile
# Optional: override base URL (default: https://api.groq.com/openai/v1)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
